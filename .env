# Ключи доступа Bybit (Рекомендуется использовать суб-аккаунт с правами на Сontrol/Trade)
BYBIT_API_KEY=your_real_api_key_here
BYBIT_API_SECRET=your_real_api_secret_here

# Настройки подключения к бирже
# Основная сеть: https://bybit.com и wss://://bybit.com
# Тестнет: https://bybit.com и wss://://bybit.com
BYBIT_BASE_URL=https://bybit.com
BYBIT_WS_URL=wss://://bybit.com

# Торговые настройки торгового тикера
TRADE_SYMBOL=BTCUSDT
TRADE_BASE_QTY=0.002
TRADE_QTY_DECIMALS=3
TRADE_PRICE_DECIMALS=1
DB_PATH=orders.db